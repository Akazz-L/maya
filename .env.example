# Required. Used by the planner/drafter/checker agents. The app boots without
# it, but every generation call fails at request time.
ANTHROPIC_API_KEY=sk-ant-...

# Required. Generate with: openssl rand -hex 32
# Changing it invalidates all existing sessions.
JWT_SECRET=change-me-to-a-random-32-byte-hex-string
JWT_EXPIRE_MINUTES=10080

# DATABASE_URL is optional. If unset, the app uses an on-disk SQLite file
# (./maya.db) that persists across restarts — zero setup for local dev.
#
# For PostgreSQL (recommended in production), set either of these — a bare
# postgres:// or postgresql:// URL, as Railway/Heroku/Fly hand out, is
# rewritten to the asyncpg driver automatically:
# DATABASE_URL=postgresql://user:password@localhost:5432/maya
