# Never ship local secrets or local database state into the image.
.env
.env copy.example
*.db
*.db-journal

# Rebuilt inside the image; copying host artifacts would defeat the cache and
# risk shipping a stale or platform-specific build.
.venv/
frontend/node_modules/
frontend/dist/
**/__pycache__/
*.pyc

.git/
.gitignore
.pytest_cache/
.claude/
.superpowers/
tests/
docs/
chapters/
summaries/
tmp_claude_call.py
